<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.kakeibo.infrastructure.CategoryMapper">

    <select id="findById" resultType="com.example.kakeibo.infrastructure.CategoryRecord">
        select
            id,
            name,
            type,
            active
        from categories
        where id = #{id}
    </select>

    <select id="findExpenseCategories" resultType="com.example.kakeibo.infrastructure.CategoryRecord">
        select
            id,
            name,
            type,
            active
        from categories
        where type = 'EXPENSE'
          and active = true
        order by id
    </select>

</mapper>